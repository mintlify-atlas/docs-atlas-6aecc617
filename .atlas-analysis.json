  "publicApiSurface": [
    "POST /api/v1/watch - Create new watch",
    "GET /api/v1/watch - List all watches",
    "GET /api/v1/watch/{uuid} - Get watch details",
    "PUT /api/v1/watch/{uuid} - Update watch",
    "DELETE /api/v1/watch/{uuid} - Delete watch",
    "GET /api/v1/watch/{uuid}/history - Get watch history",
    "GET /api/v1/tags - List all tags",
    "POST /api/v1/tags - Create new tag",
    "GET /api/v1/tags/{uuid} - Get tag details",
    "PUT /api/v1/tags/{uuid} - Update tag",
    "DELETE /api/v1/tags/{uuid} - Delete tag",
    "POST /api/v1/import - Import watches",
    "GET /api/v1/notifications - Get notification settings",
    "PUT /api/v1/notifications - Update notification settings",
    "GET /api/v1/systeminfo - Get system information",
